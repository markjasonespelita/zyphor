#!/bin/bash

# Core
source /usr/lib/zyphor/core/help
source /usr/lib/zyphor/core/version
source /usr/lib/zyphor/core/error

CATEGORY="$1"
ACTION="$2"

case "$CATEGORY" in

  pkg)
    # PKG (package management)
    source /usr/lib/zyphor/pkg/install
    source /usr/lib/zyphor/pkg/remove

    case "$ACTION" in
      install) zyphor_pkg_install "$@" ;;   # zyphor pkg install <package-name>
      remove) zyphor_pkg_remove "$@" ;;     # zyphor pkg remove <package-name>
      *) error "$CATEGORY $ACTION" ;;
    esac
    ;;

  system)
    # System
    source /usr/lib/zyphor/system/upgrade
    source /usr/lib/zyphor/system/clean

    case "$ACTION" in
      upgrade) zyphor_system_upgrade ;;     # zyphor system upgrade
      clean) zyphor_system_clean ;;         # zyphor system clean
      *) error "$CATEGORY $ACTION" ;;
    esac
    ;;

  version) version ;;                       # zyphor version
  help|"") help ;;                          # zyphor help
  *) error "$1" ;;

esac